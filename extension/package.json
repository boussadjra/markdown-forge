{
  "name": "markdown-forge",
  "displayName": "Markdown Forge",
  "description": "Serve Markdown files as a live documentation website in the browser",
  "version": "0.2.0",
  "publisher": "boussadjrabrahim",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/boussadjra/markdown-studio"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "documentation",
    "preview",
    "live-server",
    "docs"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownForge.serve",
        "title": "Serve as Website",
        "category": "Markdown Forge",
        "icon": "$(globe)"
      },
      {
        "command": "markdownForge.openInBrowser",
        "title": "Open in Browser",
        "category": "Markdown Forge",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdownForge.stop",
        "title": "Stop Server",
        "category": "Markdown Forge",
        "icon": "$(debug-stop)"
      },
      {
        "command": "markdownForge.exportSite",
        "title": "Export as Static Site",
        "category": "Markdown Forge"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownForge.serve",
          "when": "resourceLangId == markdown && !markdownForge.serverRunning",
          "group": "navigation"
        },
        {
          "command": "markdownForge.openInBrowser",
          "when": "resourceLangId == markdown && markdownForge.serverRunning",
          "group": "navigation"
        },
        {
          "command": "markdownForge.stop",
          "when": "resourceLangId == markdown && markdownForge.serverRunning",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Forge",
      "properties": {
        "markdownForge.port": {
          "type": "number",
          "default": 4200,
          "description": "Port for the Markdown Forge server"
        },
        "markdownForge.theme": {
          "type": "string",
          "default": "default",
          "description": "Active theme name"
        },
        "markdownForge.autoReload": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reload browser on file changes"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "vsce:bundle": "node ../scripts/bundle.mjs",
    "vsce:package": "pnpm run vsce:bundle && npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "@markdown-forge/server": "workspace:*",
    "@markdown-forge/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.18.0",
    "@types/markdown-it": "^14.1.2",
    "typescript": "^5.8.0"
  }
}
