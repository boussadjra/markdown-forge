{
  "name": "markdown-forge-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm build:shared && pnpm build:server && pnpm build:client && pnpm build:extension",
    "build:shared": "pnpm --filter @markdown-forge/shared build",
    "build:server": "pnpm --filter @markdown-forge/server build",
    "build:client": "pnpm --filter @markdown-forge/client build",
    "build:extension": "pnpm --filter markdown-forge build",
    "dev:client": "pnpm --filter @markdown-forge/client dev",
    "package": "pnpm --filter markdown-forge vsce:package"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boussadjra/markdown-studio"
  }
}
